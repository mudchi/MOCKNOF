<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permission to post notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Permission to use exact alarm for scheduled notifications -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- Permission to receive boot completed for persistent presets -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Vibrate for notification effect -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.MOCKNOF">

        <!-- Main Activity -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Notification Detail / Edit Activity -->
        <activity
            android:name=".ui.NotificationEditorActivity"
            android:exported="false"
            android:parentActivityName=".ui.MainActivity"
            android:windowSoftInputMode="adjustResize" />

        <!-- Preset List Activity -->
        <activity
            android:name=".ui.PresetListActivity"
            android:exported="false"
            android:parentActivityName=".ui.MainActivity" />

        <!-- History Activity -->
        <activity
            android:name=".ui.HistoryActivity"
            android:exported="false"
            android:parentActivityName=".ui.MainActivity" />

        <!-- Broadcast Receiver for scheduled / alarm notifications -->
        <receiver
            android:name=".service.NotificationAlarmReceiver"
            android:exported="false" />

        <!-- Broadcast Receiver for notification action buttons -->
        <receiver
            android:name=".service.NotificationActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.mocknof.app.ACTION_DISMISS" />
                <action android:name="com.mocknof.app.ACTION_REPLY" />
                <action android:name="com.mocknof.app.ACTION_CUSTOM" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
